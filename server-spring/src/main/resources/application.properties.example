# ─── Server ─────────────────────────────────────────────────────────────────
server.port=3001

# ─── Request Size Limits ───────────────────────────────────────────────────
server.tomcat.max-http-form-post-size=1MB
spring.servlet.multipart.max-file-size=1MB
spring.servlet.multipart.max-request-size=1MB

# ─── Database (same PostgreSQL as Node server) ──────────────────────────────
# Override with env vars: DB_URL, DB_USER, DB_PASSWORD
spring.datasource.url=${DB_URL:jdbc:postgresql://localhost:5432/sos_db}
spring.datasource.username=${DB_USER:YOUR_PG_USER}
spring.datasource.password=${DB_PASSWORD:YOUR_PG_PASSWORD}

# Hibernate auto-creates/updates tables on startup (no Prisma migrations needed)
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=false

# Run schema.sql on startup to create PostgreSQL enum types
spring.sql.init.mode=always
spring.sql.init.continue-on-error=true
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.PostgreSQLDialect

# Use physical naming as-is — @Table/@Column annotations provide exact names
spring.jpa.hibernate.naming.physical-strategy=org.hibernate.boot.model.naming.PhysicalNamingStrategyStandardImpl

# ─── Jackson ────────────────────────────────────────────────────────────────
spring.jackson.serialization.write-dates-as-timestamps=false

# ─── JWT ────────────────────────────────────────────────────────────────────
# IMPORTANT: Set JWT_SECRET env var for non-local deployments:
#   export JWT_SECRET=$(openssl rand -hex 64)
jwt.secret=${JWT_SECRET:a]3fR!9zK@7wLm$2pQxV&5nBdYhT*8cUoE+6gSjAiW0vXeN4rC1uHbMtPyDqZkGsFl}
jwt.expiration-ms=600000
jwt.max-session-seconds=43200

# ─── CORS ───────────────────────────────────────────────────────────────────
cors.allowed-origin=http://localhost:5173

# ─── Rate Limiting ──────────────────────────────────────────────────────────
rate-limit.login.max-attempts=10
rate-limit.login.window-ms=300000

# ─── Socket.IO (netty-socketio) ────────────────────────────────────────
socketio.host=0.0.0.0
socketio.port=3002
